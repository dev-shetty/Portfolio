---
import { topReads, tagSpineColors, type Genre } from "@/lib/books";

type BookSize = { height: number; width: number; lean: number };

const bookSizes: BookSize[] = [
  { height: 220, width: 56, lean: 0.3 },      
  { height: 245, width: 64, lean: 0 },        
  { height: 200, width: 58, lean: -0.3 },    
  { height: 210, width: 54, lean: 0.4 },      
  { height: 235, width: 60, lean: -0.4 },     
  { height: 225, width: 62, lean: 0 },        
];
---

<div class="bookshelf">
  <div class="shelf-back" />
  <div class="books-row">
    {topReads.map((book, i) => {
      const genre = book.tags?.[0] as Genre | undefined;
      const color = genre ? tagSpineColors[genre] : "#3a3f50";
      const { height, width, lean } = bookSizes[i] ?? { height: 200, width: 56, lean: 0 };
      return (
        <div
          class="book"
          style={`--book-color: ${color}; --book-height: ${height}px; --book-width: ${width}px; --book-lean: ${lean}deg;`}
          title={`${book.name} — ${book.author}`}
        >
          <div class="book-overlay" />
          <div class="book-wear" />
          <div class="book-spine">
            <span class="book-title">{book.name}</span>
            <span class="book-author">{book.author}</span>
          </div>
        </div>
      );
    })}
  </div>
  <div class="shelf-surface" />
  <div class="shelf-front" />
  <span class="shelf-label">my top reads so far</span>
</div>

<style>
  .bookshelf {
    width: 100%;
    position: relative;
  }

  .shelf-back {
    display: none;
  }

  .books-row {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    gap: 3px;
    padding: 0 12px;
    position: relative;
    z-index: 1;
  }

  .book {
    width: var(--book-width);
    height: var(--book-height);
    position: relative;
    cursor: default;
    transform: rotate(var(--book-lean));
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    flex-shrink: 0;

    background: linear-gradient(
      to right,
      color-mix(in srgb, var(--book-color) 85%, white 12%),
      var(--book-color) 25%,
      var(--book-color) 75%,
      color-mix(in srgb, var(--book-color) 75%, black 25%)
    );

    border-radius: 3px 5px 5px 3px;
    box-shadow:
      1px 1px 4px rgba(0, 0, 0, 0.5),
      3px 0 6px -2px rgba(0, 0, 0, 0.3),
      inset -1px 0 1px rgba(0, 0, 0, 0.2),
      inset 1px 0 1px rgba(255, 255, 255, 0.08);
  }

  /* Contact shadow at base of book */
  .book::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 2px;
    right: 2px;
    height: 4px;
    background: radial-gradient(
      ellipse at center,
      rgba(0, 0, 0, 0.5) 0%,
      transparent 70%
    );
    border-radius: 50%;
    z-index: -1;
  }

  /* Dark overlay for text contrast */
  .book-overlay {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.05),
      rgba(0, 0, 0, 0.12) 50%,
      rgba(0, 0, 0, 0.2)
    );
    pointer-events: none;
  }

  /* Worn / read texture layer */
  .book-wear {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    z-index: 1;
    background:
      /* Spine crease lines — horizontal bands from being opened */
      repeating-linear-gradient(
        to bottom,
        transparent 0px,
        transparent 18px,
        rgba(0, 0, 0, 0.06) 18px,
        rgba(0, 0, 0, 0.06) 19px,
        transparent 19px,
        transparent 35px
      ),
      /* Subtle scuff marks — faint irregular horizontal scratches */
      linear-gradient(
        to bottom,
        transparent 10%,
        rgba(255, 255, 255, 0.03) 12%,
        transparent 13%,
        transparent 28%,
        rgba(0, 0, 0, 0.04) 29%,
        transparent 30%,
        transparent 52%,
        rgba(255, 255, 255, 0.025) 53%,
        transparent 54%,
        transparent 70%,
        rgba(0, 0, 0, 0.05) 71%,
        transparent 72%,
        transparent 88%,
        rgba(255, 255, 255, 0.02) 89%,
        transparent 90%
      ),
      /* Edge fading — top and bottom sun bleach */
      linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0.06) 0%,
        transparent 8%,
        transparent 92%,
        rgba(255, 255, 255, 0.04) 100%
      ),
      /* Corner wear — lighter patches at corners */
      radial-gradient(
        ellipse at top left,
        rgba(255, 255, 255, 0.06) 0%,
        transparent 35%
      ),
      radial-gradient(
        ellipse at bottom right,
        rgba(255, 255, 255, 0.04) 0%,
        transparent 30%
      );
  }

  /* Top edge highlight */
  .book::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.1),
      transparent
    );
    border-radius: 3px 5px 0 0;
    z-index: 2;
  }

  .book:hover {
    transform: rotate(0deg) translateY(-12px);
    box-shadow:
      2px 8px 20px rgba(0, 0, 0, 0.6),
      inset -1px 0 1px rgba(0, 0, 0, 0.2),
      inset 1px 0 1px rgba(255, 255, 255, 0.08);
  }

  .book-spine {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 14px 6px;
    overflow: hidden;
    gap: 8px;
    z-index: 1;
  }

  .book-title {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1.2;
    color: rgba(255, 255, 255, 0.95);
    text-shadow:
      0 1px 3px rgba(0, 0, 0, 0.6),
      0 0 6px rgba(0, 0, 0, 0.3);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
    min-height: 0;
  }

  .book-author {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-size: 0.55rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: rgba(255, 255, 255, 0.7);
    text-shadow:
      0 1px 3px rgba(0, 0, 0, 0.6),
      0 0 6px rgba(0, 0, 0, 0.3);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex-shrink: 0;
    max-height: 60px;
  }

  /* ── Shelf surface (top) ──────────────────────── */
  .shelf-surface {
    height: 8px;
    width: calc(100% + 24px);
    margin-left: -12px;
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.07),
      rgba(255, 255, 255, 0.03)
    );
    position: relative;
    z-index: 2;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* ── Shelf front face (depth) ─────────────────── */
  .shelf-front {
    height: 14px;
    width: calc(100% + 24px);
    margin-left: -12px;
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.04),
      rgba(255, 255, 255, 0.01)
    );
    border-radius: 0 0 3px 3px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
    position: relative;
    z-index: 2;
  }

  .shelf-label {
    display: block;
    text-align: center;
    margin-top: 12px;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.05em;
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .book {
      --book-width: clamp(42px, 12vw, 60px) !important;
    }

    .book-title {
      font-size: 0.6rem;
    }

    .book-author {
      font-size: 0.48rem;
      max-height: 45px;
    }

    .books-row {
      gap: 2px;
    }

    .shelf-back {
      height: 220px;
    }
  }
</style>
