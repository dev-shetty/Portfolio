---
import { arts } from "@/lib/artgallery"
import Image from "astro/components/Image.astro"
import styles from "./art-gallery.module.css"
import ArtBook from "./ArtBook.tsx"
---

<section class="px-4">
  <div class={styles.art_container}>
    {
      arts.map((art, index) => (
        <div
          data-content={art.alt}
          data-art-index={index}
          class="relative overflow-hidden cursor-pointer"
        >
          <Image
            src={art.img}
            alt={art.alt}
            inferSize
            title={art.alt}
            sizes="100%"
            fit="cover"
            width={1000}
            height={1000}
            class="w-full h-full bg-gray-800 object-cover object-top transition-all duration-500 scale-110"
            loading={index < 8 ? "eager" : "lazy"}
          />
        </div>
      ))
    }
  </div>

  {/* Scrapbook modal – hidden on mobile */}
  <div class="hidden md:block">
    <ArtBook arts={arts} client:load />
  </div>
</section>

<script>
  // Only wire up click-to-open on md+ screens
  function initArtBookClicks() {
    if (!window.matchMedia("(min-width: 768px)").matches) return

    document.querySelectorAll("[data-art-index]").forEach((el) => {
      el.addEventListener("click", () => {
        const index = parseInt(el.getAttribute("data-art-index") || "0", 10)
        window.dispatchEvent(
          new CustomEvent("open-art-book", { detail: { index } })
        )
      })
    })
  }

  // Run on initial load and on Astro page transitions
  initArtBookClicks()
  document.addEventListener("astro:after-swap", initArtBookClicks)
</script>
